# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# AMAZON_ACCESS_KEY: Amazon PA-API OAuth Client ID.
AMAZON_ACCESS_KEY="YOUR_AMAZON_ACCESS_KEY"

# AMAZON_SECRET_KEY: Amazon PA-API OAuth Client Secret.
AMAZON_SECRET_KEY="YOUR_AMAZON_SECRET_KEY"

# ────────────────────────────────────────────────
# 自動記事生成 フォールバックLLM設定
# GitHub Actions の Secrets に設定してください
# ────────────────────────────────────────────────

# GROQ_API_KEY: Groq API キー (フォールバック②)
# 取得先: https://console.groq.com/keys
# 無料枠: 1日1,000リクエスト / Llama 3.3 70B 使用
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# OPENROUTER_API_KEY: OpenRouter APIキー (フォールバック③)
# 取得先: https://openrouter.ai/settings/keys
# 無料枠: 毎日$5相当のクレジット / Mistral-7B Instruct Free 使用
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"

# HF_API_TOKEN: Hugging Face API トークン (フォールバック④・完全無料)
# 取得先: https://huggingface.co/settings/tokens
# 無料枠: Serverless Inference API (完全無料・制限あり)
HF_API_TOKEN="YOUR_HF_API_TOKEN"
